# ──────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in at least ONE LLM provider.
# The app auto-detects which providers are configured.
# ──────────────────────────────────────────────────────────────

# ---- LLM providers (need at least one, OR run Ollama locally) ----

# Open-source / free tiers   (set key, then choose model on the next line)
GROQ_API_KEY=                # https://console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile           # also: mixtral-8x7b-32768, gemma2-9b-it
GEMINI_API_KEY=              # https://aistudio.google.com
GEMINI_MODEL=gemini-2.0-flash                # also: gemini-1.5-flash, gemini-1.5-pro
OPENROUTER_API_KEY=          # https://openrouter.ai
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free   # also: qwen/qwen-2.5-72b-instruct:free
# Ollama: no key. Run `ollama serve` + `ollama pull llama3.2`; auto-detected on :11434.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2                         # also: qwen3.5:9b, gemma2:9b

# Paid
ANTHROPIC_API_KEY=           # https://console.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6            # also: claude-opus-4-8, claude-haiku-4-5-20251001
OPENAI_API_KEY=              # https://platform.openai.com
OPENAI_MODEL=gpt-4o                          # also: gpt-4o-mini, gpt-4-turbo

# ---- Search providers (optional; enables live web research) ----
# With none set, the app runs in "LLM-knowledge only" mode.
EXA_API_KEY=                 # https://exa.ai
TAVILY_API_KEY=              # https://tavily.com
FIRECRAWL_API_KEY=           # https://firecrawl.dev

# ---- Optional overrides ----
# Force a specific LLM provider instead of auto-detect priority:
# LLM_PROVIDER=groq
# Force a specific search provider:
# SEARCH_PROVIDER=exa
