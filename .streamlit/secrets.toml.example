# ──────────────────────────────────────────────────────────────
# Streamlit Cloud secrets template.
# Copy this to your Streamlit Cloud dashboard → Settings → Secrets
# Or rename to secrets.toml for local testing.
# ──────────────────────────────────────────────────────────────

# ---- LLM providers (need at least one) ----
GROQ_API_KEY = "gsk_..."
# GROQ_MODEL = "llama-3.3-70b-versatile"

# GEMINI_API_KEY = "..."
# OPENROUTER_API_KEY = "..."
# ANTHROPIC_API_KEY = "..."
# OPENAI_API_KEY = "..."

# ---- Search providers (optional - enables live web research) ----
# EXA_API_KEY = "..."
# TAVILY_API_KEY = "..."
# FIRECRAWL_API_KEY = "..."

# ---- Optional overrides ----
# LLM_PROVIDER = "groq"
# SEARCH_PROVIDER = "exa"
